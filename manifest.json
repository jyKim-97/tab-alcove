{
  "manifest_version": 3,
  "name": "Tab Alcove",
  "version": "1.0.0",
  "description": "Automatically close or shelve inactive tabs by domain rules",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "contextMenus",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Tab Alcove"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
